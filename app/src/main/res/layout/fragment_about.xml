<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Icon -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="16dp"
            android:contentDescription="App Icon" />

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Version -->
        <TextView
            android:id="@+id/text_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_dark"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:dividerColor="@color/card_stroke" />

        <!-- GitHub Repo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/github_repo"
            android:textColor="@color/on_surface_dark"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_github_repo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Check for Updates -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_updates"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/check_for_updates"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconGravity="textStart" />

        <!-- Update Status -->
        <TextView
            android:id="@+id/text_update_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_dark"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Share Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/share_app"
            android:textSize="14sp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:strokeColor="@color/secondary" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Community alert system for weather, safety, traffic and community events."
            android:textColor="@color/on_surface_dark"
            android:textSize="13sp"
            android:alpha="0.6"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>